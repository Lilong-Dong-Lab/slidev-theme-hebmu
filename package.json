{
  "name": "slidev-theme-hebmu",
  "version": "0.1.0",
  "description": "Slidev theme for Hebei Medical University (河北医科大学) academic teaching — Chinese-first typography, bilingual layouts, and session-based structure",
  "author": {
    "name": "Hugo Dong"
  },
  "license": "MIT",
  "keywords": [
    "slidev-theme",
    "slidev",
    "academic",
    "chinese",
    "hebmu"
  ],
  "slidev": {
    "colorSchema": "both",
    "highlighter": "shiki",
    "defaults": {
      "fonts": {
        "sans": "PingFang SC",
        "mono": "Fira Code"
      },
      "themeConfig": {
        "paginationX": "r",
        "paginationY": "b"
      }
    }
  },
  "engines": {
    "slidev": ">=0.48.0"
  },
  "scripts": {
    "dev": "slidev example.md --open",
    "build": "slidev build example.md",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png"
  },
  "dependencies": {
    "@slidev/types": "^0.29.2",
    "unocss": "^0.62.3"
  },
  "devDependencies": {
    "@slidev/cli": "^51.0.0",
    "playwright-chromium": "^1.52.0"
  }
}
